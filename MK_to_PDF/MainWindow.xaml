<Window x:Class="MK_to_PDF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Markdown to PDF Converter" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/app.ico">

    <Window.Resources>
        <!-- モダンなボタンスタイル -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- アクセントボタンスタイル（PDF出力用） -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45A049"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2E7D32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- クリアボタンスタイル -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E53935"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C62828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- モダンなComboBoxスタイル -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー部分 -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- タイトルバー -->
                <TextBlock Grid.Row="0" 
                           Text="📝 Markdown to PDF Converter" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#212121"
                           Margin="0,0,0,12"/>

                <!-- コントロールバー -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左側：操作ボタン -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="OpenFileButton" 
                                Content="📂 ファイルを開く" 
                                Click="OpenFile_Click" 
                                Style="{StaticResource ModernButton}"/>

                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="4" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔤 文字コード:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#757575"/>
                                <ComboBox x:Name="EncodingComboBox" 
                                          Width="140" 
                                          SelectionChanged="EncodingComboBox_SelectionChanged" 
                                          Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="ReloadButton" 
                                Content="🔄 再読込" 
                                Click="ReloadFile_Click" 
                                Style="{StaticResource ModernButton}"/>

                        <Button x:Name="ClearFileButton" 
                                Content="🗑️ クリア" 
                                Click="ClearFile_Click" 
                                Style="{StaticResource DangerButton}"/>

                        <Button x:Name="ExportPdfButton" 
                                Content="📄 PDF出力" 
                                Click="ExportPdf_Click" 
                                Style="{StaticResource AccentButton}"
                                FontWeight="Bold"/>
                    </StackPanel>

                    <!-- 右側：ファイル情報 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="SelectedFileLabel" 
                                   Foreground="#757575" 
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- メインコンテンツエリア -->
        <Grid Grid.Row="1" Background="#F5F5F5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左パネル：エディタ -->
            <Border Grid.Column="0" Background="White" Margin="8" CornerRadius="4">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="8" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,8">
                        <TextBlock Text="✏️ Markdown Editor" FontWeight="SemiBold" Foreground="#424242"/>
                    </Border>

                    <TextBox x:Name="MarkdownEditor" 
                             Grid.Row="1"
                             AcceptsReturn="True" 
                             TextWrapping="Wrap"
                             TextChanged="MarkdownEditor_TextChanged"
                             BorderThickness="0"
                             Padding="12"
                             FontFamily="Consolas"
                             FontSize="13"
                             Background="White"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>

            <!-- スプリッター -->
            <GridSplitter Grid.Column="1" 
                          Width="4" 
                          HorizontalAlignment="Stretch" 
                          Background="#BDBDBD"
                          Cursor="SizeWE"/>

            <!-- 右パネル：プレビュー -->
            <Border Grid.Column="2" Background="White" Margin="8" CornerRadius="4">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="8" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,8">
                        <TextBlock Text="👁️ Preview" FontWeight="SemiBold" Foreground="#424242"/>
                    </Border>

                    <WebBrowser x:Name="PreviewBrowser" Grid.Row="1"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
