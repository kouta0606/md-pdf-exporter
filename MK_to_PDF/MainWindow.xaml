<Window x:Class="MK_to_PDF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MK to PDF" Height="600" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ツールバー -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="6">
            <Button x:Name="OpenFileButton" Content="ファイルを開く" Click="OpenFile_Click" Margin="0,0,6,0" />
            <TextBlock Text="文字コード:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox x:Name="EncodingComboBox" Width="120" Margin="0,0,6,0" SelectionChanged="EncodingComboBox_SelectionChanged" />
            <Button x:Name="ReloadButton" Content="再読込" Click="ReloadFile_Click" Margin="0,0,6,0" />
            <Button x:Name="ClearFileButton" Content="クリア" Click="ClearFile_Click" Margin="0,0,6,0" />
            <Button x:Name="ExportPdfButton" Content="PDF出力" Click="ExportPdf_Click" Margin="0,0,6,0" />
            <TextBlock x:Name="SelectedFileLabel" Margin="12,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <!-- 左：Markdownエディタ -->
        <TextBox x:Name="MarkdownEditor" Grid.Row="1" Grid.Column="0"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 TextChanged="MarkdownEditor_TextChanged"/>

        <!-- 右：HTMLプレビュー（組み込みの WebBrowser を使用） -->
        <WebBrowser x:Name="PreviewBrowser" Grid.Row="1" Grid.Column="1"/>
    </Grid>
</Window>
